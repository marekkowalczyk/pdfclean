#!/usr/bin/env bash

VERSION="0.1.0"

usage() {
    cat <<EOF
Usage: pdfclean [OPTIONS] [FILE...]

Compress PDF files in-place using cpdfsqueeze. If no files are given,
processes all *.pdf files in the current directory.

Options:
  --dry-run     Report what would be compressed without modifying files
  --version     Print version and exit
  --help        Print this help and exit

Examples:
  pdfclean                    # compress all *.pdf in current dir
  pdfclean a.pdf b.pdf        # compress specific files
  pdfclean --dry-run *.pdf    # preview without changing files
EOF
}

dry_run=0
exit_code=0

# Parse flags
args=()
for arg in "$@"; do
    case "$arg" in
        --help)    usage; exit 0 ;;
        --version) echo "pdfclean $VERSION"; exit 0 ;;
        --dry-run) dry_run=1 ;;
        *)         args+=("$arg") ;;
    esac
done

# Determine file list
if [ ${#args[@]} -eq 0 ]; then
    files=( *.pdf )
    echo "No argument supplied, assuming '*.pdf'"
else
    files=("${args[@]}")
fi

# Deduplicate, warning on repeats
seen=()
unique_files=()
for f in "${files[@]}"; do
    already=0
    for s in "${seen[@]}"; do
        [ "$s" = "$f" ] && already=1 && break
    done
    if [ "$already" -eq 1 ]; then
        echo "Warning: '$f' specified more than once, skipping duplicate" >&2
    else
        seen+=("$f")
        unique_files+=("$f")
    fi
done
files=("${unique_files[@]}")

echo "Files to process: ${files[@]}"

n=${#files[@]}

for ((i=1; i<=n; i++)); do
    file="${files[i-1]}"

    if [ ! -f "$file" ]; then
        echo "Warning: '$file' not found, skipping..." >&2
        exit_code=1
        continue
    fi

    printf "\033[7m\nProcessing %s (%d of %d)\033[27m\n" "${file}" $i $n

    initial_size=$(stat -f%z "$file" 2>/dev/null || stat --format="%s" "$file")

    if [ "$dry_run" -eq 1 ]; then
        if cpdfsqueeze "${file}" "${file}.tmp" 2>/dev/null; then
            final_size=$(stat -f%z "${file}.tmp" 2>/dev/null || stat --format="%s" "${file}.tmp")
            rm "${file}.tmp"
            if [ "$final_size" -lt "$initial_size" ]; then
                reduction=$((initial_size - final_size))
                percent=$(awk "BEGIN {printf \"%.1f\", ($reduction / $initial_size) * 100}")
                echo "[dry-run] Would reduce by $reduction bytes ($percent%)"
            else
                echo "[dry-run] No size reduction would be achieved"
            fi
        else
            [ -f "${file}.tmp" ] && rm "${file}.tmp"
            echo "Error: cpdfsqueeze failed on '$file'" >&2
            exit_code=1
        fi
        continue
    fi

    if cpdfsqueeze "${file}" "${file}.tmp"; then
        final_size=$(stat -f%z "${file}.tmp" 2>/dev/null || stat --format="%s" "${file}.tmp")

        if [ "$final_size" -lt "$initial_size" ]; then
            mv "${file}.tmp" "${file}"
            reduction=$((initial_size - final_size))
            percent=$(awk "BEGIN {printf \"%.1f\", ($reduction / $initial_size) * 100}")
            echo "Compressed: reduced by $reduction bytes ($percent%)"
        else
            rm "${file}.tmp"
            echo "No size reduction achieved - keeping original file"
        fi
    else
        echo "Error: Failed to compress '$file'" >&2
        exit_code=1
        [ -f "${file}.tmp" ] && rm "${file}.tmp"
    fi
done

echo -e "\nProcessing completed for $n files"
exit $exit_code
