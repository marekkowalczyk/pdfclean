#!/usr/bin/env bash

VERSION="0.1.0"

usage() {
    cat <<EOF
Usage: pdfclean [OPTIONS] [-- ] [FILE... | . | --all]

Compress PDF files in-place using cpdfsqueeze.

Options:
  --all, -a        Process all *.pdf / *.PDF files in the current directory
  --dry-run, -n    Report what would be compressed without modifying files
  --quiet, -q      Suppress all non-error output
  --version        Print version and exit
  --help           Print this help and exit
  --               End of options; remaining args treated as filenames

Passing . is equivalent to --all.

Examples:
  pdfclean .              # compress all *.pdf / *.PDF in current dir
  pdfclean -a             # same
  pdfclean a.pdf b.pdf    # compress specific files
  pdfclean -n .           # preview without changing files
  pdfclean -- -odd.pdf    # process a file whose name starts with -
EOF
}


dry_run=0
quiet=0
exit_code=0
end_of_opts=0

# Parse flags
args=()
all=0
for arg in "$@"; do
    if [ "$end_of_opts" -eq 1 ]; then
        args+=("$arg")
        continue
    fi
    case "$arg" in
        --help)          usage; exit 0 ;;
        --version)       echo "pdfclean $VERSION"; exit 0 ;;
        --dry-run|-n)    dry_run=1 ;;
        --quiet|-q)      quiet=1 ;;
        --all|-a|.)      all=1 ;;
        --)              end_of_opts=1 ;;
        *)               args+=("$arg") ;;
    esac
done

log() { [ "$quiet" -eq 0 ] && echo "$@"; }

# Determine file list
if [ "$all" -eq 1 ] && [ ${#args[@]} -gt 0 ]; then
    echo "pdfclean: cannot combine . / --all with explicit filenames" >&2
    exit 1
elif [ "$all" -eq 1 ]; then
    expanded=()
    for f in *.pdf *.PDF; do
        [ -f "$f" ] && expanded+=("$f")
    done
    files=("${expanded[@]}")
    if [ ${#files[@]} -eq 0 ]; then
        echo "pdfclean: no PDF files found in current directory" >&2
        exit 1
    fi
elif [ ${#args[@]} -eq 0 ]; then
    echo "pdfclean: no files specified; try 'pdfclean --help'" >&2
    exit 1
else
    files=("${args[@]}")
fi

# Deduplicate, warning on repeats
seen=()
unique_files=()
for f in "${files[@]}"; do
    already=0
    for s in "${seen[@]}"; do
        [ "$s" = "$f" ] && already=1 && break
    done
    if [ "$already" -eq 1 ]; then
        echo "pdfclean: '$f' specified more than once, skipping duplicate" >&2
    else
        seen+=("$f")
        unique_files+=("$f")
    fi
done
files=("${unique_files[@]}")

tmpfile=""

# Clean up temp file on exit/interrupt
cleanup() { [ -n "$tmpfile" ] && rm -f "$tmpfile"; }
trap cleanup INT TERM EXIT

for file in "${files[@]}"; do
    # Normalize filenames starting with - so tools don't treat them as flags
    [[ "$file" == -* ]] && file="./$file"

    if [ ! -f "$file" ]; then
        echo "pdfclean: '$file' not found, skipping" >&2
        exit_code=1
        continue
    fi

    initial_size=$(stat -f%z "$file" 2>/dev/null || stat --format="%s" "$file")

    # Create temp file in same directory as the source (same filesystem = atomic mv)
    dir=$(dirname "$file")
    tmpfile=$(mktemp "${dir}/.pdfclean.XXXXXX")

    if [ "$dry_run" -eq 1 ]; then
        if cpdfsqueeze "${file}" "$tmpfile" >/dev/null 2>&1; then
            final_size=$(stat -f%z "$tmpfile" 2>/dev/null || stat --format="%s" "$tmpfile")
            if [ "$final_size" -lt "$initial_size" ]; then
                reduction=$((initial_size - final_size))
                percent=$(awk "BEGIN {printf \"%.1f\", ($reduction / $initial_size) * 100}")
                log "$file: [dry-run] would reduce by $reduction bytes ($percent%)"
            fi
        else
            echo "pdfclean: cpdfsqueeze failed on '$file'" >&2
            exit_code=1
        fi
        rm -f "$tmpfile"
        tmpfile=""
        continue
    fi

    if cpdfsqueeze "${file}" "$tmpfile" >/dev/null 2>&1; then
        final_size=$(stat -f%z "$tmpfile" 2>/dev/null || stat --format="%s" "$tmpfile")

        if [ "$final_size" -lt "$initial_size" ]; then
            mv "$tmpfile" "${file}"
            tmpfile=""
            reduction=$((initial_size - final_size))
            percent=$(awk "BEGIN {printf \"%.1f\", ($reduction / $initial_size) * 100}")
            log "$file: reduced by $reduction bytes ($percent%)"
        else
            rm -f "$tmpfile"
            tmpfile=""
        fi
    else
        echo "pdfclean: failed to compress '$file'" >&2
        exit_code=1
        rm -f "$tmpfile"
        tmpfile=""
    fi
done

exit $exit_code
